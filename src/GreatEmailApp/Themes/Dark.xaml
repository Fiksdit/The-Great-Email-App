<!-- FILE: src/GreatEmailApp/Themes/Dark.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 1
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Color tokens for dark mode. Same keys as Light.xaml; ThemeManager swaps dictionaries. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent (overridden at runtime by ThemeManager) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3A6FF8" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5085FF" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#2A5AD6" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#2E5085FF" />
    <SolidColorBrush x:Key="AccentSofterBrush" Color="#1A5085FF" />
    <SolidColorBrush x:Key="AccentOnBrush" Color="#FFFFFF" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="GreenBrush" Color="#14A37F" />
    <SolidColorBrush x:Key="AmberBrush" Color="#D29014" />
    <SolidColorBrush x:Key="RoseBrush" Color="#D4406B" />
    <SolidColorBrush x:Key="VioletBrush" Color="#8A5CF5" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#202020" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#262626" />
    <SolidColorBrush x:Key="PaneBackgroundBrush" Color="#262626" />
    <SolidColorBrush x:Key="Pane2BackgroundBrush" Color="#2C2C2C" />
    <SolidColorBrush x:Key="ElevatedBackgroundBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="ActiveBackgroundBrush" Color="#16FFFFFF" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1C1C1C" />
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#0FFFFFFF" />

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C7F5F5F5" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8CF5F5F5" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#52F5F5F5" />
    <SolidColorBrush x:Key="OnAccentTextBrush" Color="#FFFFFF" />

    <!-- Borders / dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#29FFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#2EFFFFFF" />
    <SolidColorBrush x:Key="DividerBrush" Color="#0FFFFFFF" />

    <Color x:Key="ShadowColor">#80000000</Color>

</ResourceDictionary>
