<!-- FILE: src/GreatEmailApp/Themes/Light.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 1
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Color tokens for light mode. Brush keys are stable across themes; ThemeManager swaps the dictionary. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent (overridden at runtime by ThemeManager) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3A6FF8" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5085FF" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#2A5AD6" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#1A3A6FF8" />
    <SolidColorBrush x:Key="AccentSofterBrush" Color="#0F3A6FF8" />
    <SolidColorBrush x:Key="AccentOnBrush" Color="#FFFFFF" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="GreenBrush" Color="#14A37F" />
    <SolidColorBrush x:Key="AmberBrush" Color="#D29014" />
    <SolidColorBrush x:Key="RoseBrush" Color="#D4406B" />
    <SolidColorBrush x:Key="VioletBrush" Color="#8A5CF5" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F9F9F9" />
    <SolidColorBrush x:Key="PaneBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Pane2BackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="ElevatedBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#0B000000" />
    <SolidColorBrush x:Key="ActiveBackgroundBrush" Color="#12000000" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#0A000000" />

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B81A1A1A" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8C1A1A1A" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#591A1A1A" />
    <SolidColorBrush x:Key="OnAccentTextBrush" Color="#FFFFFF" />

    <!-- Borders / dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#14000000" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#24000000" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#2E000000" />
    <SolidColorBrush x:Key="DividerBrush" Color="#0F000000" />

    <!-- Drop shadows (used as DropShadowEffect Color) -->
    <Color x:Key="ShadowColor">#33000000</Color>

</ResourceDictionary>
