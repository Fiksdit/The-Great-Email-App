<!-- FILE: src/GreatEmailApp/MainWindow.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 1
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Composition: TitleBar / Ribbon / [Sidebar | MailList | ReadingPane] / StatusBar.
     Splitters between sidebar and mail list, and between mail list and reading pane,
     enforce min/max widths from Tokens.xaml. -->
<Window x:Class="GreatEmailApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:GreatEmailApp.Controls"
        xmlns:vm="clr-namespace:GreatEmailApp.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="The Great Email App"
        Height="720" Width="1200" MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title bar -->
            <RowDefinition Height="Auto" />  <!-- ribbon -->
            <RowDefinition Height="*" />     <!-- 3-pane body -->
            <RowDefinition Height="Auto" />  <!-- status bar -->
        </Grid.RowDefinitions>

        <c:TitleBar Grid.Row="0"
                    AccountInitial="{Binding AccountInitial}"
                    AccountEmail="{Binding AccountEmail}" />

        <c:Ribbon Grid.Row="1" />

        <!-- 3-pane body -->
        <Grid Grid.Row="2" Background="{DynamicResource PaneBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="264"
                                  MinWidth="{StaticResource SidebarMinWidth}"
                                  MaxWidth="{StaticResource SidebarMaxWidth}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="380"
                                  MinWidth="{StaticResource MailListMinWidth}"
                                  MaxWidth="{StaticResource MailListMaxWidth}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <c:Sidebar Grid.Column="0" />

            <GridSplitter Grid.Column="1" Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DividerBrush}"
                          ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Cursor="SizeWE" />

            <c:MailList Grid.Column="2" />

            <GridSplitter Grid.Column="3" Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DividerBrush}"
                          ShowsPreview="False"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Cursor="SizeWE" />

            <c:ReadingPane Grid.Column="4" />
        </Grid>

        <c:AppStatusBar Grid.Row="3" />
    </Grid>
</Window>
