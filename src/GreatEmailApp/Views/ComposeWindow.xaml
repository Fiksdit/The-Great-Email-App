     Created: 2026-04-30 | Revised: 2026-05-01 | Rev: 2
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Standalone window — not modal — so the user can keep reading while composing. -->
<Window x:Class="GreatEmailApp.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GreatEmailApp.ViewModels"
        xmlns:c="clr-namespace:GreatEmailApp.Controls"
        xmlns:conv="clr-namespace:GreatEmailApp.Converters"
        Title="New message"
        Width="780" Height="640" MinWidth="540" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        ShowInTaskbar="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:CollectionNotEmptyToVisibilityConverter x:Key="CollNotEmpty" />

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="56" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ElevatedBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="Auto" />  <!-- Headers -->
            <RowDefinition Height="Auto" />  <!-- Attachments -->
            <RowDefinition Height="*" />     <!-- Body -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource Pane2BackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource AccentButton}"
                        Content="Send"
                        Padding="20,8" FontWeight="SemiBold"
                        Command="{Binding SendCommand}" />
                <Button Style="{StaticResource SubtleButton}"
                        Content="Attach"
                        Padding="14,7" Margin="8,0,0,0"
                        Command="{Binding AddAttachmentCommand}" />
                <Button Style="{StaticResource SubtleButton}"
                        Content="Cc / Bcc"
                        Padding="14,7" Margin="8,0,0,0"
                        Command="{Binding ToggleCcBccCommand}" />
                <Button Style="{StaticResource SubtleButton}"
                        Content="Save draft"
                        Padding="14,7" Margin="8,0,0,0"
                        Click="SaveDraft_Click" />
                <Button Style="{StaticResource SubtleButton}"
                        Content="Discard"
                        Padding="14,7" Margin="8,0,0,0"
                        Click="Discard_Click" />
            </StackPanel>
        </Border>

        <!-- Headers -->
        <Border Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}" Padding="14,10,14,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- From -->
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="From" />
                <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,3"
                           ItemsSource="{Binding AvailableAccounts}"
                           DisplayMemberPath="EmailAddress"
                           SelectedItem="{Binding FromAccount}" />

                <!-- To -->
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="To" />
                <c:AddressInput Grid.Row="1" Grid.Column="1" x:Name="ToInput"
                                Text="{Binding ToAddresses, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Cc -->
                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Cc"
                           Visibility="{Binding CcBccVisible, Converter={StaticResource BoolVis}}" />
                <c:AddressInput Grid.Row="2" Grid.Column="1" x:Name="CcInput"
                                Text="{Binding CcAddresses, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding CcBccVisible, Converter={StaticResource BoolVis}}" />

                <!-- Bcc -->
                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bcc"
                           Visibility="{Binding CcBccVisible, Converter={StaticResource BoolVis}}" />
                <c:AddressInput Grid.Row="3" Grid.Column="1" x:Name="BccInput"
                                Text="{Binding BccAddresses, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding CcBccVisible, Converter={StaticResource BoolVis}}" />

                <!-- Subject -->
                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Subject" />
                <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldBox}"
                           Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <!-- Attachments -->
        <Border Grid.Row="2"
                Visibility="{Binding Attachments, Converter={StaticResource CollNotEmpty}}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Padding="14,8">
            <ItemsControl ItemsSource="{Binding Attachments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource ElevatedBackgroundBrush}"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Text=" · " Foreground="{DynamicResource TertiaryTextBrush}" />
                                <TextBlock Text="{Binding SizeText}" FontSize="12"
                                           Foreground="{DynamicResource TertiaryTextBrush}" />
                                <Button Content="✕" Margin="8,0,0,0"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        Cursor="Hand" Padding="4,0"
                                        Command="{Binding DataContext.RemoveAttachmentCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Body -->
        <c:RichTextEditor Grid.Row="3" x:Name="BodyEditor" />

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource Pane2BackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{DynamicResource TertiaryTextBrush}"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
