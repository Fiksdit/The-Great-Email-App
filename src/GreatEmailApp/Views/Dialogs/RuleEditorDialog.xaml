     Single-rule editor. Modal over the Settings dialog. -->
<Window x:Class="GreatEmailApp.Views.Dialogs.RuleEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rule"
        Height="540" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Name + enabled -->
            <RowDefinition Height="Auto" />  <!-- Account scope -->
            <RowDefinition Height="Auto" />  <!-- Match radio -->
            <RowDefinition Height="*"    />  <!-- Conditions + actions -->
            <RowDefinition Height="Auto" />  <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- Name + enabled -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Rule name" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBox x:Name="NameBox" Margin="0,4,0,0" Padding="6,5"
                         Background="{DynamicResource ElevatedBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                         CaretBrush="{DynamicResource PrimaryTextBrush}" />
            </StackPanel>
            <CheckBox Grid.Column="1" x:Name="EnabledCheck"
                      Content="Enabled" Margin="16,18,0,0"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource SecondaryTextBrush}" />
        </Grid>

        <!-- Account scope -->
        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Apply to" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
            <ComboBox x:Name="AccountCombo" Margin="0,4,0,0"
                      DisplayMemberPath="DisplayName" SelectedValuePath="Id" />
        </StackPanel>

        <!-- Match radio -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock Text="Match" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
            <RadioButton x:Name="MatchAll" Content="all conditions" GroupName="Match"
                         Foreground="{DynamicResource PrimaryTextBrush}" Margin="12,0,0,0" IsChecked="True" />
            <RadioButton x:Name="MatchAny" Content="any condition" GroupName="Match"
                         Foreground="{DynamicResource PrimaryTextBrush}" Margin="12,0,0,0" />
            <CheckBox x:Name="StopOnMatchCheck" Content="Stop processing further rules"
                      Margin="24,0,0,0"
                      Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Conditions + actions -->
        <ScrollViewer Grid.Row="3" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                            Content="+ Add condition" Padding="10,4" Click="AddCondition_Click" />
                    <TextBlock Text="Conditions" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl x:Name="ConditionsList" Margin="0,0,0,16" />

                <DockPanel LastChildFill="True" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                            Content="+ Add action" Padding="10,4" Click="AddAction_Click" />
                    <TextBlock Text="Actions" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl x:Name="ActionsList" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource SubtleButton}" Content="Cancel"
                    Padding="14,7" IsCancel="True" />
            <Button Style="{StaticResource AccentButton}" Content="Save"
                    Margin="8,0,0,0" Padding="14,7" Click="Save_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
