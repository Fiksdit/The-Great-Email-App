<!-- FILE: src/GreatEmailApp/Controls/Ribbon.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 2
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Outlook-style ribbon. Tabs: File · Home · Send/Receive · View · Help. -->
<UserControl x:Class="GreatEmailApp.Controls.Ribbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GreatEmailApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:StringEqualsToBoolConverter x:Key="StrEqBool" />
        <conv:StringEqualsToVisibilityConverter x:Key="StrEqVis" />

        <Style x:Key="RibbonTabButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="Indicator" Height="2" VerticalAlignment="Bottom"
                                    Margin="14,0" Background="{DynamicResource AccentBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileTabButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large primary button (icon block on top, label below) -->
        <Style x:Key="RibbonLargeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActiveBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard ribbon item: icon on top, single-line label below, all in one row -->
        <Style x:Key="RibbonItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActiveBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RibbonIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ActiveBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical separator between groups -->
        <Style x:Key="GroupSep" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="6,8" />
            <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PaneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="68" />
        </Grid.RowDefinitions>

        <!-- Tabs row -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource Pane2BackgroundBrush}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource FileTabButton}" Click="FileTab_Click">File</Button>
                <ToggleButton Style="{StaticResource RibbonTabButton}"
                              IsChecked="{Binding ActiveRibbonTab, Converter={StaticResource StrEqBool}, ConverterParameter=Home, Mode=OneWay}"
                              Click="Tab_Click" Tag="Home" Content="Home" />
                <ToggleButton Style="{StaticResource RibbonTabButton}"
                              IsChecked="{Binding ActiveRibbonTab, Converter={StaticResource StrEqBool}, ConverterParameter=SendReceive, Mode=OneWay}"
                              Click="Tab_Click" Tag="SendReceive" Content="Send / Receive" />
                <ToggleButton Style="{StaticResource RibbonTabButton}"
                              IsChecked="{Binding ActiveRibbonTab, Converter={StaticResource StrEqBool}, ConverterParameter=View, Mode=OneWay}"
                              Click="Tab_Click" Tag="View" Content="View" />
                <ToggleButton Style="{StaticResource RibbonTabButton}"
                              IsChecked="{Binding ActiveRibbonTab, Converter={StaticResource StrEqBool}, ConverterParameter=Help, Mode=OneWay}"
                              Click="Tab_Click" Tag="Help" Content="Help" />
            </StackPanel>
        </Border>

        <!-- Ribbon body -->
        <Border Grid.Row="1" Background="{DynamicResource PaneBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <!-- HOME -->
                <Grid Visibility="{Binding ActiveRibbonTab, Converter={StaticResource StrEqVis}, ConverterParameter=Home}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                            <Button Style="{StaticResource RibbonLargeButton}">
                                <StackPanel>
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource AccentBrush}" Margin="0,0,0,2">
                                        <TextBlock Text="{StaticResource IconNewMail}" Style="{StaticResource IconGlyph}"
                                                   Foreground="White" FontSize="15" />
                                    </Border>
                                    <TextBlock Text="New Email" FontSize="11" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </StackPanel>
                            </Button>
                            <Border Style="{StaticResource GroupSep}" />
                            <Button Style="{StaticResource RibbonItemButton}" Command="{Binding DeleteCommand}">
                                <StackPanel><TextBlock Text="{StaticResource IconTrash}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Delete" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}" Command="{Binding ArchiveCommand}">
                                <StackPanel><TextBlock Text="{StaticResource IconArchive}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Archive" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}" Command="{Binding JunkCommand}">
                                <StackPanel><TextBlock Text="{StaticResource IconJunk}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Junk" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Border Style="{StaticResource GroupSep}" />
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconReply}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Reply" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconReplyAll}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Reply All" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconForward}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Forward" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Border Style="{StaticResource GroupSep}" />
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconMove}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Move" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconRules}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Rules" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}" Command="{Binding ToggleReadCommand}">
                                <StackPanel><TextBlock Text="{StaticResource IconUnread}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Mark Read/Unread" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Border Style="{StaticResource GroupSep}" />
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconCategorize}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Categorize" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}" Command="{Binding ToggleFlagCommand}">
                                <StackPanel><TextBlock Text="{StaticResource IconFollowUp}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Flag" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonItemButton}">
                                <StackPanel><TextBlock Text="{StaticResource IconContact}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Search People" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- SEND / RECEIVE -->
                <Grid Visibility="{Binding ActiveRibbonTab, Converter={StaticResource StrEqVis}, ConverterParameter=SendReceive}">
                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                        <Button Style="{StaticResource RibbonLargeButton}">
                            <StackPanel>
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="{DynamicResource AccentSoftBrush}" Margin="0,0,0,2">
                                    <TextBlock Text="{StaticResource IconSync}" Style="{StaticResource IconGlyph}"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="15" />
                                </Border>
                                <TextBlock Text="Send/Receive" FontSize="11" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource GroupSep}" />
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconRefresh}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Update Folder" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconSent}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Send All" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconOffline}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Work Offline" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- VIEW -->
                <Grid Visibility="{Binding ActiveRibbonTab, Converter={StaticResource StrEqVis}, ConverterParameter=View}">
                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconReadingPane}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Reading Pane" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconFolder}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Folder Pane" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconRefresh}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Reset View" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Border Style="{StaticResource GroupSep}" />
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconChevronDown}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Sort By" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconChevronDown}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Arrange By" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconChevronDown}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Density" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- HELP -->
                <Grid Visibility="{Binding ActiveRibbonTab, Converter={StaticResource StrEqVis}, ConverterParameter=Help}">
                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                        <Button Style="{StaticResource RibbonLargeButton}">
                            <StackPanel>
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="{DynamicResource AccentSoftBrush}" Margin="0,0,0,2">
                                    <TextBlock Text="{StaticResource IconHelp}" Style="{StaticResource IconGlyph}"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="15" />
                                </Border>
                                <TextBlock Text="Help" FontSize="11" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Border Style="{StaticResource GroupSep}" />
                        <Button Style="{StaticResource RibbonItemButton}" Click="OnSettings_Click">
                            <StackPanel><TextBlock Text="{StaticResource IconSettings}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Settings" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}">
                            <StackPanel><TextBlock Text="{StaticResource IconContact}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Account Settings" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonItemButton}" Click="OnCheckForUpdates_Click">
                            <StackPanel><TextBlock Text="{StaticResource IconRefresh}" Style="{StaticResource IconGlyph}" FontSize="16" /><TextBlock Text="Check for Updates" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
