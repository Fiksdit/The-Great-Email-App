<UserControl x:Class="GreatEmailApp.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Height="{DynamicResource TitleBarHeight}">
    <Border Background="{DynamicResource TitleBarBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,8,0"
                        Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="G" Foreground="White" FontWeight="Bold" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="The Great Email App" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Search -->
            <Grid Grid.Column="1" Margin="16,6" MaxWidth="540" Height="24"
                  HorizontalAlignment="Center">
                <Border x:Name="SearchHost"
                        Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{StaticResource IconSearch}"
                                   Style="{StaticResource IconGlyph}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 FontSize="12"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 KeyDown="SearchBox_KeyDown"
                                 LostFocus="SearchBox_LostFocus" />
                        <TextBlock x:Name="SearchPlaceholder"
                                   Grid.Column="1"
                                   Text="Search mail (sender, subject, body…)"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>

                <Popup x:Name="ResultsPopup"
                       PlacementTarget="{Binding ElementName=SearchHost}"
                       Placement="Bottom"
                       Width="540"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <Border Background="{DynamicResource ElevatedBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4"
                            MaxHeight="420">
                        <Grid>
                            <TextBlock x:Name="ResultsEmpty"
                                       Text="No matches."
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       FontSize="12" Margin="12,8" Visibility="Collapsed" />
                            <ListBox x:Name="ResultsList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionMode="Single"
                                     MouseLeftButtonUp="ResultsList_MouseLeftButtonUp"
                                     KeyDown="ResultsList_KeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="10,8" Margin="0,1">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding AccountEmail}"
                                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                                           FontSize="11" Margin="8,0,0,0" />
                                                <TextBlock Text="{Binding Sender}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Subject}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Snippet}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- Sync indicator -->
            <Border Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center"
                    Background="{DynamicResource ChipBackgroundBrush}"
                    CornerRadius="4" Padding="8,3">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource GreenBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="Sync on" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Avatar + window controls -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="AvatarButton" Style="{StaticResource SubtleButton}"
                        Padding="4" Margin="0,0,6,0"
                        Click="AvatarButton_Click"
                        ToolTip="{Binding AccountEmail, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="{Binding AccountInitial, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Foreground="White" FontSize="10" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Button>
                <Button Style="{StaticResource SubtleButton}" Width="40" Height="36"
                        Padding="0" Click="Min_Click">
                    <TextBlock Text="{StaticResource IconMin}" Style="{StaticResource IconGlyph}" FontSize="10" />
                </Button>
                <Button x:Name="MaxButton" Style="{StaticResource SubtleButton}" Width="40" Height="36"
                        Padding="0" Click="Max_Click">
                    <TextBlock x:Name="MaxGlyph" Text="{StaticResource IconMax}" Style="{StaticResource IconGlyph}" FontSize="10" />
                </Button>
                <Button Style="{StaticResource SubtleButton}" Width="40" Height="36"
                        Padding="0" Click="Close_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="{StaticResource IconClose}" Style="{StaticResource IconGlyph}" FontSize="10" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
