<!-- FILE: src/GreatEmailApp/Controls/MessageBodyView.xaml
     Created: 2026-04-30 | Revised: 2026-04-30 | Rev: 1
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Renders an email body — HTML in WebView2 (script disabled, remote http(s)
     blocked unless AppSettings.AllowRemoteImages is true) or plain text fallback. -->
<UserControl x:Class="GreatEmailApp.Controls.MessageBodyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Inline banner shown when remote content was blocked. Click to allow it
             once for this message. Permanent toggle lives in Settings → Security. -->
        <Border x:Name="BlockedBanner" Grid.Row="0"
                Background="#332E5085" Padding="12,8"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        x:Name="ShowImagesButton"
                        Content="Show images"
                        Style="{StaticResource SubtleButton}"
                        Padding="10,4"
                        Click="ShowImagesOnce_Click" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="12"
                           Text="Remote images and content are blocked. Click to load them for this message." />
            </DockPanel>
        </Border>

        <!-- WebView2 host. Plain-text fallback uses the same surface — we just
             wrap text in a minimal HTML doc so the dark theme + word wrap apply. -->
        <wv2:WebView2 Grid.Row="1" x:Name="Web" />
    </Grid>
</UserControl>
