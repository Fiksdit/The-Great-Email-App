     contenteditable WebView2 editor with a tiny formatting toolbar.
     Used by ComposeWindow for HTML body authoring. -->
<UserControl x:Class="GreatEmailApp.Controls.RichTextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource AppBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource FontSans}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource Pane2BackgroundBrush}" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Bold (Ctrl+B)"   Click="OnBold"      FontWeight="Bold">B</Button>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Italic (Ctrl+I)" Click="OnItalic"    FontStyle="Italic">I</Button>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Underline (Ctrl+U)" Click="OnUnderline">
                    <TextBlock Text="U" TextDecorations="Underline" />
                </Button>
                <Border Width="1" Margin="6,2" Background="{DynamicResource DividerBrush}" />
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Bulleted list" Click="OnBullets">•⁃</Button>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Numbered list" Click="OnNumbers">1.</Button>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Block quote"   Click="OnQuote">"</Button>
                <Border Width="1" Margin="6,2" Background="{DynamicResource DividerBrush}" />
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Insert link"   Click="OnLink">🔗</Button>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Clear formatting" Click="OnClearFormat">✕</Button>
            </StackPanel>
        </Border>

        <wv2:WebView2 Grid.Row="1" x:Name="Web" />
    </Grid>
</UserControl>
