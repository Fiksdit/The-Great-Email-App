<!-- FILE: src/GreatEmailApp/Controls/MailList.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 1
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Middle pane — message list with grouping, filter pills, search. -->
<UserControl x:Class="GreatEmailApp.Controls.MailList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GreatEmailApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:BoolToFontWeightConverter x:Key="BoolWeight" />
        <conv:StringEqualsToBoolConverter x:Key="StrEqBool" />

        <Style x:Key="FilterPill" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="13" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource PaneBackgroundBrush}">
        <DockPanel>
            <!-- Top: search + filter pills -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                    Padding="12,10">
                <StackPanel>
                    <Border Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,0" Height="28">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource IconSearch}" Style="{StaticResource IconGlyph}"
                                       FontSize="12" Margin="0,0,6,0"
                                       Foreground="{DynamicResource TertiaryTextBrush}" />
                            <TextBlock Text="Search current folder"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ToggleButton Style="{StaticResource FilterPill}" Content="All"
                                      IsChecked="{Binding Filter, Converter={StaticResource StrEqBool}, ConverterParameter=All, Mode=OneWay}"
                                      Click="Pill_Click" Tag="All" />
                        <ToggleButton Style="{StaticResource FilterPill}" Content="Unread" Margin="4,0,0,0"
                                      IsChecked="{Binding Filter, Converter={StaticResource StrEqBool}, ConverterParameter=Unread, Mode=OneWay}"
                                      Click="Pill_Click" Tag="Unread" />
                        <ToggleButton Style="{StaticResource FilterPill}" Content="Flagged" Margin="4,0,0,0"
                                      IsChecked="{Binding Filter, Converter={StaticResource StrEqBool}, ConverterParameter=Flagged, Mode=OneWay}"
                                      Click="Pill_Click" Tag="Flagged" />
                        <ToggleButton Style="{StaticResource FilterPill}" Content="Mentions" Margin="4,0,0,0"
                                      IsChecked="{Binding Filter, Converter={StaticResource StrEqBool}, ConverterParameter=Mentions, Mode=OneWay}"
                                      Click="Pill_Click" Tag="Mentions" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group header (only shows when needed; controlled in code-behind via attached property would be cleaner;
                                     for Phase 1 we render every group label and let the eye scan — matches the design) -->
                                <TextBlock Text="{Binding Group}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                           Margin="14,12,0,4"
                                           Visibility="{Binding IsFirstInGroup, Converter={StaticResource BoolVis}}" />

                                <Border x:Name="Row" Background="Transparent" CornerRadius="6"
                                        Margin="6,1" Padding="0"
                                        MouseLeftButtonDown="Row_Click" Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Unread accent bar -->
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Background="{DynamicResource AccentBrush}" Margin="2,8"
                                                Visibility="{Binding Unread, Converter={StaticResource BoolVis}}" />

                                        <!-- Avatar -->
                                        <Border Grid.Column="1" Width="32" Height="32" CornerRadius="16"
                                                Background="{Binding AvatarBrush}" Margin="6,8,10,8"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Avatar}"
                                                       Foreground="White" FontWeight="SemiBold" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Body -->
                                        <StackPanel Grid.Column="2" Margin="0,8,8,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Sender}"
                                                           FontWeight="{Binding Unread, Converter={StaticResource BoolWeight}}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Time}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                                           Margin="6,1,0,0" />
                                            </Grid>
                                            <TextBlock Text="{Binding Subject}"
                                                       FontSize="12"
                                                       FontWeight="{Binding Unread, Converter={StaticResource BoolWeight}}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                            <TextBlock Text="{Binding Preview}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                        </StackPanel>

                                        <!-- Right indicators -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,10,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="{StaticResource IconAttach}" Style="{StaticResource IconGlyph}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       Margin="0,0,4,0"
                                                       Visibility="{Binding HasAttachments, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Text="{StaticResource IconFlagFilled}" Style="{StaticResource IconGlyph}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource RoseBrush}"
                                                       Margin="0,0,4,0"
                                                       Visibility="{Binding Flagged, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Text="{StaticResource IconImportant}" Style="{StaticResource IconGlyph}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AmberBrush}"
                                                       Visibility="{Binding Important, Converter={StaticResource BoolVis}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
