<UserControl x:Class="GreatEmailApp.Controls.ReadingPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GreatEmailApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:NullToVisibilityConverter x:Key="NullVis" />
        <conv:CollectionNotEmptyToVisibilityConverter x:Key="CollNotEmpty" />
        <conv:HexToBrushConverter x:Key="HexBrush" />
    </UserControl.Resources>

    <Border Background="{DynamicResource Pane2BackgroundBrush}">
        <Grid>
            <!-- Empty state -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                  Visibility="{Binding SelectedMessage, Converter={StaticResource NullVis}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{StaticResource IconMail}" Style="{StaticResource IconGlyph}"
                               FontSize="48" Foreground="{DynamicResource TertiaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="No message selected" Margin="0,12,0,0"
                               Foreground="{DynamicResource TertiaryTextBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Message body -->
            <DockPanel DataContext="{Binding SelectedMessage}"
                       Visibility="{Binding ., Converter={StaticResource NullVis}}">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                    Background="{Binding AvatarBrush}" Margin="0,0,12,0">
                                <TextBlock Text="{Binding Avatar}" Foreground="White"
                                           FontWeight="SemiBold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Sender}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="{Binding SenderEmail}"
                                           FontSize="12" Foreground="{DynamicResource TertiaryTextBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding FullTime}"
                                       FontSize="12" Foreground="{DynamicResource TertiaryTextBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding Subject}" Style="{StaticResource TextHeading}"
                                   Margin="0,12,0,8" TextWrapping="Wrap" />

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="To:" Margin="0,0,8,0"
                                       Foreground="{DynamicResource TertiaryTextBrush}" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="{Binding To}" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Style="{StaticResource AccentButton}" Content="Reply" />
                            <Button Style="{StaticResource SubtleButton}" Margin="6,0,0,0" Padding="12,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconReplyAll}" Style="{StaticResource IconGlyph}"
                                               FontSize="13" Margin="0,0,6,0" />
                                    <TextBlock Text="Reply All" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SubtleButton}" Margin="2,0,0,0" Padding="12,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconForward}" Style="{StaticResource IconGlyph}"
                                               FontSize="13" Margin="0,0,6,0" />
                                    <TextBlock Text="Forward" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Border Width="1" Margin="8,4" Background="{DynamicResource DividerBrush}" />
                            <Button Style="{StaticResource SubtleButton}" Padding="8,7" ToolTip="Archive"
                                    Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock Text="{StaticResource IconArchive}" Style="{StaticResource IconGlyph}" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource SubtleButton}" Padding="8,7" ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock Text="{StaticResource IconTrash}" Style="{StaticResource IconGlyph}" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource SubtleButton}" Padding="8,7" ToolTip="Flag"
                                    Command="{Binding DataContext.ToggleFlagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock Text="{StaticResource IconFlag}" Style="{StaticResource IconGlyph}" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource SubtleButton}" Padding="8,7" ToolTip="Mark read/unread"
                                    Command="{Binding DataContext.ToggleReadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock Text="{StaticResource IconUnread}" Style="{StaticResource IconGlyph}" FontSize="13" />
                            </Button>
                            <Button Style="{StaticResource SubtleButton}" Padding="8,7">
                                <TextBlock Text="{StaticResource IconMore}" Style="{StaticResource IconGlyph}" FontSize="13" />
                            </Button>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,14,0,0"
                                      Visibility="{Binding Attachments, Converter={StaticResource CollNotEmpty}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ChipBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8,6" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" CornerRadius="4"
                                                    Background="{Binding Color, Converter={StaticResource HexBrush}}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Extension}"
                                                           Foreground="White" FontWeight="SemiBold" FontSize="10"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium" />
                                                <TextBlock Text="{Binding Size}" FontSize="11"
                                                           Foreground="{DynamicResource TertiaryTextBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <TextBlock Text="{Binding BodyDisplay}"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="13" />
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
