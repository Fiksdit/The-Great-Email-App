     Account/folder tree. Each account collapses/expands. -->
<UserControl x:Class="GreatEmailApp.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GreatEmailApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:IntGreaterThanZeroToVisibilityConverter x:Key="UnreadVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0">
        <DockPanel>
            <!-- Add account row -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                    Padding="10,8">
                <Button Style="{StaticResource SubtleButton}" Padding="6,4" HorizontalContentAlignment="Left"
                        Click="AddAccount_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource IconAdd}" Style="{StaticResource IconGlyph}"
                                   FontSize="13" Margin="2,0,8,0" />
                        <TextBlock Text="Add account" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </Button>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Account header -->
                                <Border Background="Transparent" Margin="6,8,6,2" CornerRadius="6"
                                        Padding="6,4" Cursor="Hand"
                                        MouseLeftButtonDown="AccountHeader_Click" Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{StaticResource IconChevronDown}"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                                   Margin="2,0,8,0" />
                                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="11"
                                                Background="{Binding ColorBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding EmailAddress}"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Ellipse Grid.Column="3" Width="8" Height="8"
                                                 Fill="{Binding StatusBrush}" Margin="6,0,4,0" />
                                    </Grid>
                                </Border>

                                <!-- Folders -->
                                <ItemsControl ItemsSource="{Binding Folders}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="FolderRow" Background="Transparent" CornerRadius="6"
                                                    Margin="6,1" Cursor="Hand"
                                                    MouseLeftButtonDown="FolderRow_Click" Tag="{Binding}">
                                                <Grid Height="28">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border Width="14"
                                                                Visibility="{Binding IsNested, Converter={StaticResource BoolVis}}" />
                                                        <TextBlock Text="•" Margin="14,0,8,0" FontSize="14"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               FontSize="13" />
                                                    <Border Grid.Column="2" Margin="6,0,10,0"
                                                            Padding="6,1" CornerRadius="9"
                                                            Background="{DynamicResource ChipBackgroundBrush}"
                                                            Visibility="{Binding UnreadCount, Converter={StaticResource UnreadVis}}">
                                                        <TextBlock Text="{Binding UnreadCount}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="FolderRow" Property="Background"
                                                            Value="{DynamicResource AccentSoftBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
