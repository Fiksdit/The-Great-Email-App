<!-- FILE: src/GreatEmailApp/Controls/Sidebar.xaml
     Created: 2026-04-29 | Revised: 2026-04-29 | Rev: 3
     Changed by: Claude Opus 4.7 on behalf of James Reed
     Account/folder tree. Accounts collapse/expand at top level. Folders nest
     recursively via a self-referential DataTemplate (FolderItemTemplate) — each
     folder VM has its own Children collection and IsExpanded flag, so any depth
     of sub-folders gets its own caret + collapse behavior. -->
<UserControl x:Class="GreatEmailApp.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GreatEmailApp.ViewModels"
             xmlns:conv="clr-namespace:GreatEmailApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:IntGreaterThanZeroToVisibilityConverter x:Key="UnreadVis" />

        <!-- Recursive folder template. Self-references via {DynamicResource FolderItemTemplate}. -->
        <DataTemplate x:Key="FolderItemTemplate" DataType="{x:Type vm:FolderViewModel}">
            <StackPanel>
                <Border x:Name="FolderRow" Background="Transparent" CornerRadius="6"
                        Margin="6,1" Cursor="Hand"
                        MouseLeftButtonDown="FolderRow_Click"
                        PreviewMouseRightButtonDown="FolderRow_RightClick"
                        Tag="{Binding}">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open" Click="OpenFolder_Click" />
                            <MenuItem Header="Mark all as read" Click="MarkFolderRead_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <MenuItem Header="New subfolder…" Click="NewSubfolder_Click" />
                            <MenuItem Header="Rename folder…" Click="RenameFolder_Click" />
                            <MenuItem Header="Delete folder…" Click="DeleteFolder_Click" />
                            <Separator Style="{StaticResource MenuSeparatorStyle}" />
                            <MenuItem Header="Empty folder…" Click="EmptyFolder_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />     <!-- caret area -->
                            <ColumnDefinition Width="*" />      <!-- name -->
                            <ColumnDefinition Width="Auto" />   <!-- unread chip -->
                        </Grid.ColumnDefinitions>

                        <!-- Caret: only clickable when HasChildren. Bubbling MouseLeftButtonDown
                             fires here BEFORE the parent FolderRow handler, so we can
                             set e.Handled=true and prevent the click from selecting the folder. -->
                        <Border Grid.Column="0" Background="Transparent"
                                MouseLeftButtonDown="FolderCaret_Click" Tag="{Binding}">
                            <TextBlock x:Name="Caret"
                                       Text="{StaticResource IconChevronDown}"
                                       FontFamily="{DynamicResource FontIcons}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasChildren, Converter={StaticResource BoolVis}}" />
                        </Border>

                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="2" Margin="6,0,10,0"
                                Padding="6,1" CornerRadius="9"
                                Background="{DynamicResource ChipBackgroundBrush}"
                                Visibility="{Binding BadgeCount, Converter={StaticResource UnreadVis}}">
                            <TextBlock Text="{Binding BadgeCount}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Recursive children, indented. Visibility toggled by IsExpanded. -->
                <ItemsControl ItemsSource="{Binding Children}"
                              ItemTemplate="{DynamicResource FolderItemTemplate}"
                              Margin="14,0,0,0"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="FolderRow" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                    <Setter TargetName="Caret" Property="Text" Value="{StaticResource IconChevronRight}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0">
        <DockPanel>
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0"
                    Padding="10,8">
                <Button Style="{StaticResource SubtleButton}" Padding="6,4" HorizontalContentAlignment="Left"
                        Click="AddAccount_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource IconAdd}" Style="{StaticResource IconGlyph}"
                                   FontSize="13" Margin="2,0,8,0" />
                        <TextBlock Text="Add account" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </Button>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AccountViewModel}">
                            <StackPanel>
                                <!-- Account header -->
                                <Border Background="Transparent" Margin="6,8,6,2" CornerRadius="6"
                                        Padding="6,4" Cursor="Hand"
                                        PreviewMouseLeftButtonDown="AccountHeader_Click" Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="AccountCaret" Grid.Column="0"
                                                   Text="{StaticResource IconChevronDown}"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                                   Margin="2,0,8,0" />
                                        <Border Grid.Column="1" Width="22" Height="22" CornerRadius="11"
                                                Background="{Binding ColorBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding EmailAddress}"
                                                       Foreground="{DynamicResource TertiaryTextBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Ellipse Grid.Column="3" Width="8" Height="8"
                                                 Fill="{Binding StatusBrush}" Margin="6,0,4,0" />
                                    </Grid>
                                </Border>

                                <!-- Folders (recursive) -->
                                <ItemsControl ItemsSource="{Binding Folders}"
                                              ItemTemplate="{DynamicResource FolderItemTemplate}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}" />
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                    <Setter TargetName="AccountCaret" Property="Text" Value="{StaticResource IconChevronRight}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
